# easy-db-lab local developer overrides
#
# Copy this file to .env and fill in your values.
# .env is gitignored and never committed.
# Variables set in your shell always take precedence over .env.
#
# Usage:
#   cp .env.example .env
#   # edit .env with your values
#   bin/end-to-end-test --spark --no-teardown

# AWS profile to use for all AWS CLI and SDK operations.
# Must be configured in ~/.aws/config or ~/.aws/credentials.
AWS_PROFILE=your-aws-profile

# Override the EC2 instance type used for database nodes.
# Default: c5d.2xlarge
# EASY_DB_LAB_INSTANCE_TYPE=c5d.2xlarge

# Custom Cassandra sidecar container image.
# Set this to use an IAM-capable or otherwise custom sidecar build.
# Default: ghcr.io/apache/cassandra-sidecar:latest
# SIDECAR_IMAGE=102382809497.dkr.ecr.us-west-2.amazonaws.com/rustyrazorblade/cassandra-sidecar
