#!/bin/bash
# This script is for local development
# The release bin script is generated by the gradle build

dir=$(dirname $0)

APP_HOME="$(dirname "$dir")"
APP_HOME=$(readlink -f $APP_HOME)

# Load per-developer overrides from .env (gitignored). Shell env always wins.
if [ -f "$APP_HOME/.env" ]; then
    set -a
    # shellcheck disable=SC1091
    source "$APP_HOME/.env"
    set +a
fi

EASY_DB_LAB_USER_DATA=~/.easy-db-lab/

VERSION=$(grep '^version' "${APP_HOME}/gradle.properties" | cut -d '=' -f2)

JAR="${APP_HOME}/build/libs/easy-db-lab-${VERSION}-all.jar"
OTEL_AGENT="${APP_HOME}/build/install/easy-db-lab/agents/opentelemetry-javaagent.jar"

# Start OTel collector (opt-in: set EASY_DB_LAB_USE_DOCKER=1 to enable)
if [ "${EASY_DB_LAB_USE_DOCKER}" = "1" ]; then
    COMPOSE_OUTPUT=$(docker compose -p easy-db-lab -f "${APP_HOME}/docker-compose.yml" up -d 2>&1)
    COMPOSE_EXIT=$?
    if [ $COMPOSE_EXIT -ne 0 ]; then
        echo "$COMPOSE_OUTPUT" >&2
        echo "Failed to start OTel collector" >&2
        exit 1
    fi

    # Discover the dynamically assigned port
    OTEL_PORT=$(docker compose -p easy-db-lab -f "${APP_HOME}/docker-compose.yml" port otel-collector 4317 2>/dev/null | cut -d: -f2)
    export OTEL_EXPORTER_OTLP_ENDPOINT="http://localhost:${OTEL_PORT}"
    export EASY_DB_LAB_REDIS_URL="redis://localhost:6399/easydblab-events"
fi

# Load the OTel agent only when the collector is running
OTEL_AGENT_ARG=""
if [ "${EASY_DB_LAB_USE_DOCKER}" = "1" ]; then
    # Route OTel agent logs through application logger (logback) instead of stdout
    # This prevents agent messages from polluting machine-readable output (like JSON policies)
    export OTEL_JAVAAGENT_LOGGING=application
    OTEL_AGENT_ARG="-javaagent:${OTEL_AGENT}"
fi

# async-profiler (opt-in: set EASY_DB_LAB_PROFILING=1 to enable)
ASYNC_PROFILER_VERSION="3.0"
ASYNC_PROFILER_LIB="${APP_HOME}/.async-profiler/lib/libasyncProfiler.dylib"
PROFILER_AGENT_ARG=""

if [ "${EASY_DB_LAB_PROFILING}" = "1" ]; then
    mkdir -p "${APP_HOME}/profiles"

    if [ ! -f "${ASYNC_PROFILER_LIB}" ]; then
        echo "Downloading async-profiler ${ASYNC_PROFILER_VERSION}..." >&2
        DOWNLOAD_URL="https://github.com/async-profiler/async-profiler/releases/download/v${ASYNC_PROFILER_VERSION}/async-profiler-${ASYNC_PROFILER_VERSION}-macos.zip"
        TMP_ZIP=$(mktemp /tmp/async-profiler-XXXXXX.zip)
        mkdir -p "$(dirname "${ASYNC_PROFILER_LIB}")"
        curl -fsSL -o "${TMP_ZIP}" "${DOWNLOAD_URL}"
        unzip -jo "${TMP_ZIP}" "*/lib/libasyncProfiler.dylib" -d "$(dirname "${ASYNC_PROFILER_LIB}")"
        rm -f "${TMP_ZIP}"
        # Remove macOS quarantine flag so the dylib can load as a JVM agent
        xattr -d com.apple.quarantine "${ASYNC_PROFILER_LIB}" 2>/dev/null || true
        echo "async-profiler installed to $(dirname "${ASYNC_PROFILER_LIB}")" >&2
    fi

    PROFILE_FILE="${APP_HOME}/profiles/profile-$(date +%Y%m%d-%H%M%S).html"
    PROFILER_AGENT_ARG="-agentpath:${ASYNC_PROFILER_LIB}=start,event=wall,interval=5ms,threads,file=${PROFILE_FILE}"
    echo "Profiling enabled → ${PROFILE_FILE}" >&2
fi

java -Xshare:off -Deasydblab.version=$VERSION -Deasydblab.apphome=$APP_HOME ${OTEL_AGENT_ARG} ${PROFILER_AGENT_ARG} -jar $JAR "$@"
