#!/bin/bash
# This script is for local development
# The release bin script is generated by the gradle build

dir=$(dirname $0)

APP_HOME="$(dirname "$dir")"
APP_HOME=$(readlink -f $APP_HOME)

EASY_DB_LAB_USER_DATA=~/.easy-db-lab/

VERSION=$(grep '^version' "${APP_HOME}/gradle.properties" | cut -d '=' -f2)

JAR="${APP_HOME}/build/libs/easy-db-lab-${VERSION}-all.jar"
OTEL_AGENT="${APP_HOME}/build/install/easy-db-lab/agents/opentelemetry-javaagent.jar"

# Start OTel collector
if [ "${EASY_DB_LAB_SKIP_DOCKER}" != "1" ]; then
    COMPOSE_OUTPUT=$(docker compose -f "${APP_HOME}/docker-compose.yml" up -d 2>&1)
    COMPOSE_EXIT=$?
    if [ $COMPOSE_EXIT -ne 0 ]; then
        echo "$COMPOSE_OUTPUT" >&2
        if echo "$COMPOSE_OUTPUT" | grep -q "already in use"; then
            echo "" >&2
            echo "To resolve: remove the conflicting container(s), then retry:" >&2
            echo "  docker rm -f easydblab-otel-collector easydblab-valkey" >&2
        else
            echo "Failed to start OTel collector" >&2
        fi
        exit 1
    fi
fi

# Discover the dynamically assigned port
OTEL_PORT=$(docker compose -f "${APP_HOME}/docker-compose.yml" port otel-collector 4317 2>/dev/null | cut -d: -f2)
export OTEL_EXPORTER_OTLP_ENDPOINT="http://localhost:${OTEL_PORT}"
export EASY_DB_LAB_REDIS_URL="redis://localhost:6399/easydblab-events"

# Route OTel agent logs through application logger (logback) instead of stdout
# This prevents agent messages from polluting machine-readable output (like JSON policies)
export OTEL_JAVAAGENT_LOGGING=application

java -Xshare:off -Deasydblab.version=$VERSION -Deasydblab.apphome=$APP_HOME -javaagent:"$OTEL_AGENT" -jar $JAR "$@"
