{
  "annotations": {
    "list": []
  },
  "description": "Compare Cassandra cluster throughput, latency, and health side by side. All panel types demonstrated — Polystat, Time Series, Status History, Bar Chart, Heatmap, and Percentile Ladder Table.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "id": 100,
      "title": "1. Fleet Snapshot — Current health at a glance across all clusters",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "description": "One row per cluster. Write ops/s, write p99, read p99, and error rate. Cells colored by threshold.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": {"type": "auto"},
            "inspect": false
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 5000},
              {"color": "red", "value": 20000}
            ]
          }
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "Write ops/s"},
            "properties": [
              {"id": "unit", "value": "reqps"},
              {"id": "thresholds", "value": {"mode": "absolute", "steps": [{"color": "green", "value": null}]}},
              {"id": "custom.cellOptions", "value": {"type": "color-background"}}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "Write p99"},
            "properties": [
              {"id": "unit", "value": "µs"},
              {"id": "thresholds", "value": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 5000}, {"color": "red", "value": 20000}]}},
              {"id": "custom.cellOptions", "value": {"type": "color-background"}}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "Read p99"},
            "properties": [
              {"id": "unit", "value": "µs"},
              {"id": "thresholds", "value": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 5000}, {"color": "red", "value": 20000}]}},
              {"id": "custom.cellOptions", "value": {"type": "color-background"}}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "Error rate"},
            "properties": [
              {"id": "unit", "value": "reqps"},
              {"id": "thresholds", "value": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "red", "value": 0.001}]}},
              {"id": "custom.cellOptions", "value": {"type": "color-background"}}
            ]
          }
        ]
      },
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 1},
      "id": 3,
      "options": {
        "cellHeight": "sm",
        "footer": {"countRows": false, "fields": "", "reducer": ["sum"], "show": false},
        "showHeader": true,
        "sortBy": [{"desc": true, "displayName": "Write ops/s"}]
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "sum by (cluster) (rate({__name__=~\"org_apache_cassandra_metrics_client_request_latency_write_.+_count\", cluster=~\"$cluster\"}[$__rate_interval]))",
          "legendFormat": "Write ops/s",
          "refId": "A",
          "instant": true
        },
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "histogram_quantile(0.99, sum by (le, cluster) (rate({__name__=~\"org_apache_cassandra_metrics_client_request_latency_write_.+_bucket\", cluster=~\"$cluster\"}[$__rate_interval])))",
          "legendFormat": "Write p99",
          "refId": "B",
          "instant": true
        },
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "histogram_quantile(0.99, sum by (le, cluster) (rate({__name__=~\"org_apache_cassandra_metrics_client_request_latency_read_.+_bucket\", cluster=~\"$cluster\"}[$__rate_interval])))",
          "legendFormat": "Read p99",
          "refId": "C",
          "instant": true
        },
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "sum by (cluster) (rate({__name__=~\"org_apache_cassandra_metrics_client_request_failures_(read|write)_.+_total\", cluster=~\"$cluster\"}[$__rate_interval]))",
          "legendFormat": "Error rate",
          "refId": "D",
          "instant": true
        }
      ],
      "title": "Cluster Summary",
      "transformations": [
        {"id": "merge", "options": {}}
      ],
      "type": "table"
    },
    {
      "collapsed": false,
