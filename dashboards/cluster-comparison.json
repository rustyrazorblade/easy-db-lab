    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "description": "Mathematically correct cluster-level p99: histogram buckets are re-aggregated per cluster before applying histogram_quantile.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
