{
  "title": "Tempo",
  "uid": "tempo-overview",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "pluginId": "prometheus",
        "query": "prometheus",
        "label": "Data Source",
        "hide": 0,
        "refresh": 1,
        "multi": false,
        "includeAll": false,
        "current": {
          "selected": true,
          "text": "VictoriaMetrics",
          "value": "VictoriaMetrics"
        }
      },
      {
        "name": "cluster",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "label": "Cluster",
        "hide": 0,
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "query": {
          "qryType": 1,
          "query": "label_values(traces_spanmetrics_calls_total, cluster)",
          "refId": "PrometheusVariableQueryEditor-VariableQuery"
        },
        "sort": 1
      },
      {
        "name": "service",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "label": "Service",
        "hide": 0,
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "query": {
          "qryType": 1,
          "query": "label_values(traces_spanmetrics_calls_total, service_name)",
          "refId": "PrometheusVariableQueryEditor-VariableQuery"
        },
        "sort": 1
      },
      {
        "name": "filters",
        "type": "adhocfilters",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        }
      }
    ]
  },
  "panels": [
