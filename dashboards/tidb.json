{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "datasource",
          "uid": "grafana"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "target": {
          "limit": 100,
          "matchAny": false,
          "tags": [],
          "type": "dashboard"
        },
        "type": "dashboard"
      }
    ]
  },
  "description": "TiDB cluster metrics: SQL layer (TiDB), placement driver (PD), row store (TiKV), columnar store (TiFlash)",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "panels": [],
      "title": "TiDB Cluster Overview",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Active SQL connections to TiDB",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": { "h": 3, "w": 4, "x": 0, "y": 1 },
      "id": 2,
      "options": { "colorMode": "background", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "targets": [{ "expr": "sum(tidb_server_connections)", "legendFormat": "Connections", "refId": "A" }],
      "title": "Active Connections",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Total number of Raft regions",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": { "h": 3, "w": 4, "x": 4, "y": 1 },
      "id": 3,
      "options": { "colorMode": "background", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "targets": [{ "expr": "pd_cluster_status{type=\"region_count\"}", "legendFormat": "Regions", "refId": "A" }],
      "title": "Region Count",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Number of TiKV stores currently up",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": { "h": 3, "w": 4, "x": 8, "y": 1 },
      "id": 4,
      "options": { "colorMode": "background", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "targets": [{ "expr": "pd_cluster_status{type=\"store_up_count\"}", "legendFormat": "Stores Up", "refId": "A" }],
      "title": "Stores Up",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Number of TiKV stores currently down — should be 0",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] },
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": { "h": 3, "w": 4, "x": 12, "y": 1 },
      "id": 5,
      "options": { "colorMode": "background", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "targets": [{ "expr": "pd_cluster_status{type=\"store_down_count\"}", "legendFormat": "Stores Down", "refId": "A" }],
      "title": "Stores Down",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Percentage of cluster storage used",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 70 }, { "color": "red", "value": 90 }] },
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": { "h": 3, "w": 4, "x": 16, "y": 1 },
      "id": 6,
      "options": { "colorMode": "background", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "targets": [{ "expr": "100 * pd_cluster_status{type=\"storage_size\"} / pd_cluster_status{type=\"storage_capacity\"}", "legendFormat": "Storage Used %", "refId": "A" }],
      "title": "Storage Used %",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "DDL job queue depth",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 5 }] },
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": { "h": 3, "w": 4, "x": 20, "y": 1 },
      "id": 7,
      "options": { "colorMode": "background", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "targets": [{ "expr": "sum(tidb_ddl_waiting_jobs)", "legendFormat": "Waiting DDL Jobs", "refId": "A" }],
      "title": "DDL Waiting Jobs",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 8 },
      "id": 8,
      "panels": [],
      "title": "TiDB SQL",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Rate of SQL statements executed per second, broken down by statement type",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 10, "lineWidth": 1 }, "unit": "reqps" },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 9 },
      "id": 9,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [{ "expr": "rate(tidb_executor_statement_total[5m])", "legendFormat": "{{type}}", "refId": "A" }],
      "title": "Statement Rate by Type",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Rate of SQL execution errors per second",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 10, "lineWidth": 1 }, "unit": "reqps" },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 9 },
      "id": 10,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [{ "expr": "rate(tidb_server_execute_error_total[5m])", "legendFormat": "{{type}}", "refId": "A" }],
      "title": "Execution Error Rate",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Active SQL connections over time",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 10, "lineWidth": 1 }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 16 },
      "id": 11,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [{ "expr": "sum(tidb_server_connections)", "legendFormat": "Connections", "refId": "A" }],
      "title": "Active Connections Over Time",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Rate of critical (non-recoverable) errors",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 10, "lineWidth": 1 }, "unit": "reqps" },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 16 },
      "id": 12,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [{ "expr": "rate(tidb_server_critical_error_total[5m])", "legendFormat": "{{type}}", "refId": "A" }],
      "title": "Critical Error Rate",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "50th and 99th percentile query handle duration — key latency signal for the SQL layer",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 10, "lineWidth": 1 }, "unit": "s" },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 23 },
      "id": 35,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "histogram_quantile(0.99, sum by (le, instance) (rate(tidb_server_handle_query_duration_seconds_bucket[5m])))", "legendFormat": "p99 {{instance}}", "refId": "A" },
        { "expr": "histogram_quantile(0.50, sum by (le, instance) (rate(tidb_server_handle_query_duration_seconds_bucket[5m])))", "legendFormat": "p50 {{instance}}", "refId": "B" }
      ],
      "title": "Query Latency (p50/p99)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Plan cache hit and miss rates — high miss rate means the optimizer re-plans frequently, adding CPU overhead",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 10, "lineWidth": 1 }, "unit": "reqps" },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 23 },
      "id": 36,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "rate(tidb_server_plan_cache_total[5m])", "legendFormat": "hits {{type}}", "refId": "A" },
        { "expr": "rate(tidb_server_plan_cache_miss_total[5m])", "legendFormat": "misses {{type}}", "refId": "B" }
      ],
      "title": "Plan Cache Hit/Miss Rate",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Rate of queries offloaded to the TiFlash MPP engine — rising rate confirms HTAP pushdown is working",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 10, "lineWidth": 1 }, "unit": "reqps" },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 30 },
      "id": 37,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [{ "expr": "rate(tidb_server_tiflash_query_total[5m])", "legendFormat": "{{type}}", "refId": "A" }],
      "title": "TiFlash Offload Rate",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Region errors returned to the SQL layer from TiKV — auto-retried but indicate TiKV instability or leader election churn",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 10, "lineWidth": 1 }, "unit": "reqps" },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 30 },
      "id": 38,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [{ "expr": "rate(tidb_tikvclient_region_err_total[5m])", "legendFormat": "{{type}}", "refId": "A" }],
      "title": "TiKV Client Region Errors",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 38 },
      "id": 13,
      "panels": [],
      "title": "PD (Placement Driver)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Number of TiKV stores currently up",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": { "h": 3, "w": 4, "x": 0, "y": 39 },
      "id": 14,
      "options": { "colorMode": "background", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "targets": [{ "expr": "pd_cluster_status{type=\"store_up_count\"}", "legendFormat": "Stores Up", "refId": "A" }],
      "title": "Stores Up",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Number of TiKV stores currently down — alert if > 0",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] },
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": { "h": 3, "w": 4, "x": 4, "y": 39 },
      "id": 15,
      "options": { "colorMode": "background", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "targets": [{ "expr": "pd_cluster_status{type=\"store_down_count\"}", "legendFormat": "Stores Down", "refId": "A" }],
      "title": "Stores Down",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Total cluster storage capacity in bytes",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "bytes"
        },
        "overrides": []
      },
      "gridPos": { "h": 3, "w": 4, "x": 8, "y": 39 },
      "id": 16,
      "options": { "colorMode": "background", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "targets": [{ "expr": "pd_cluster_status{type=\"storage_capacity\"}", "legendFormat": "Capacity", "refId": "A" }],
      "title": "Storage Capacity",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Currently used cluster storage in bytes",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "bytes"
        },
        "overrides": []
      },
      "gridPos": { "h": 3, "w": 4, "x": 12, "y": 39 },
      "id": 17,
      "options": { "colorMode": "background", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "targets": [{ "expr": "pd_cluster_status{type=\"storage_size\"}", "legendFormat": "Storage Used", "refId": "A" }],
      "title": "Storage Used",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "TSO operations per second — timestamp oracle throughput",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 10, "lineWidth": 1 }, "unit": "reqps" },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 42 },
      "id": 18,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [{ "expr": "rate(pd_cluster_tso[5m])", "legendFormat": "{{type}}", "refId": "A" }],
      "title": "TSO Operations Rate",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Region count over time",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 10, "lineWidth": 1 }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 42 },
      "id": 19,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "pd_cluster_status{type=\"region_count\"}", "legendFormat": "Regions", "refId": "A" },
        { "expr": "pd_cluster_status{type=\"leader_count\"}", "legendFormat": "Leaders", "refId": "B" }
      ],
      "title": "Region and Leader Count Over Time",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "TSO clock skew in milliseconds",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 10, "lineWidth": 1 }, "unit": "ms" },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 49 },
      "id": 20,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [{ "expr": "pd_cluster_tso_gap_millionseconds", "legendFormat": "{{instance}}", "refId": "A" }],
      "title": "TSO Clock Skew",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Rate of scheduling operators created by PD (balance-region, balance-leader, etc.) — a spike indicates active rebalancing",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 10, "lineWidth": 1 }, "unit": "reqps" },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 56 },
      "id": 39,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [{ "expr": "rate(pd_schedule_operators_count_total[5m])", "legendFormat": "{{type}}", "refId": "A" }],
      "title": "Scheduling Operator Rate",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Regions in each health state — elevated missing-peer or extra-peer counts indicate replication issues",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 10, "lineWidth": 1 }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 56 },
      "id": 40,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [{ "expr": "pd_regions_status", "legendFormat": "{{type}}", "refId": "A" }],
      "title": "Region Health States",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Regions pending each PD checker (replica, merge, split) — a growing count indicates scheduling backlog",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 10, "lineWidth": 1 }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 63 },
      "id": 41,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [{ "expr": "pd_checker_region_list", "legendFormat": "{{type}}", "refId": "A" }],
      "title": "Checker Region List",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Hot region and store counts by type — elevated values indicate uneven load distribution",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 10, "lineWidth": 1 }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 63 },
      "id": 42,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [{ "expr": "pd_hotspot_status", "legendFormat": "{{type}}", "refId": "A" }],
      "title": "Hotspot Status",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 70 },
      "id": 21,
      "panels": [],
      "title": "TiKV (Row Store)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Missing Raft leaders per store — should be 0",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] },
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": { "h": 3, "w": 12, "x": 0, "y": 71 },
      "id": 22,
      "options": { "colorMode": "background", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "targets": [{ "expr": "sum(tikv_raftstore_leader_missing)", "legendFormat": "Missing Leaders", "refId": "A" }],
      "title": "Missing Raft Leaders",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Hibernated Raft peers (idle regions conserving resources)",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": { "h": 3, "w": 12, "x": 12, "y": 71 },
      "id": 23,
      "options": { "colorMode": "background", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "targets": [{ "expr": "sum(tikv_raftstore_hibernated_peer_state)", "legendFormat": "Hibernated Peers", "refId": "A" }],
      "title": "Hibernated Raft Peers",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
