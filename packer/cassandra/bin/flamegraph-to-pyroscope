#!/bin/bash

# flamegraph-to-pyroscope: Continuously profile Cassandra and send data to Pyroscope.
#
# Runs in a loop: profiles for FLAMEGRAPH_INTERVAL seconds (default: 60), uploads
# the collapsed-stack file to Pyroscope, then repeats. Runs until stopped (SIGTERM).
#
# Configuration via /etc/default/flamegraph-cassandra:
#   FLAMEGRAPH_INTERVAL=60        Profile duration per upload cycle in seconds
#   FLAMEGRAPH_EXTRA_ARGS="-e alloc -t"   Extra asprof options (space-separated)
#
# The Cassandra PID is auto-detected via cassandra-pid.

set -e

ASPROF=/usr/local/async-profiler/bin/asprof
# Include hostname so each node's profile is stored separately in Pyroscope
APP_NAME="cassandra.$(hostname)"

# Source environment for Pyroscope address
# shellcheck source=/dev/null
[ -f /etc/default/cassandra ] && source /etc/default/cassandra

# Source optional per-node profiler config (interval and extra args)
# shellcheck source=/dev/null
[ -f /etc/default/flamegraph-cassandra ] && source /etc/default/flamegraph-cassandra

PYROSCOPE_ADDR="${PYROSCOPE_SERVER_ADDRESS:-http://localhost:4040}"
INTERVAL="${FLAMEGRAPH_INTERVAL:-60}"

# FLAMEGRAPH_EXTRA_ARGS may contain space-separated asprof options, e.g. "-e alloc"
# Word-split intentionally to build an array from the env var.
# shellcheck disable=SC2206
EXTRA_ARGS=($FLAMEGRAPH_EXTRA_ARGS)

# Get the Cassandra PID
PID=$(cassandra-pid)

if [ -z "$PID" ] || [ "$PID" = "0" ]; then
    echo "Error: Could not determine Cassandra PID" >&2
    exit 1
fi

echo "Starting continuous profiling (interval: ${INTERVAL}s, PID: $PID, app: $APP_NAME)..."

OUTFILE=""

cleanup() {
    rm -f "$OUTFILE"
}
trap cleanup EXIT

while true; do
    OUTFILE=$(mktemp /tmp/flamegraph-XXXXXX.collapsed)
    FROM=$(date +%s)
    sudo "$ASPROF" -o collapsed -f "$OUTFILE" -d "$INTERVAL" "${EXTRA_ARGS[@]}" "$PID"
    UNTIL=$(date +%s)

    curl -sf -X POST \
        "${PYROSCOPE_ADDR}/ingest?name=${APP_NAME}&spyName=asyncprofiler&format=collapsed&from=${FROM}&until=${UNTIL}" \
        -H "Content-Type: text/plain" \
        --data-binary @"$OUTFILE" \
        || echo "Upload failed (Pyroscope unreachable?), continuing profiling loop."

    rm -f "$OUTFILE"
    OUTFILE=""
    echo "Cycle complete at $(date -Iseconds), profile sent to Pyroscope."
done
