#!/bin/bash

# flamegraph-to-pyroscope: Continuous profiling using async-profiler --loop, uploading to Pyroscope.
#
# Uses asprof's native --loop mode: profiles continuously, writing one collapsed-stack
# file per interval. Each completed file is uploaded to Pyroscope and removed.
# Runs until stopped (SIGTERM from systemd).
#
# Configuration via /etc/default/flamegraph-cassandra:
#   FLAMEGRAPH_INTERVAL=60              Profile duration per upload cycle (seconds)
#   FLAMEGRAPH_EXTRA_ARGS="-e alloc -t" Extra asprof options (space-separated)
#
# The Cassandra PID is auto-detected via cassandra-pid.

set -e

ASPROF=/usr/local/async-profiler/bin/asprof
# Include hostname so each node's profile is stored separately in Pyroscope
APP_NAME="cassandra.$(hostname)"
OUTDIR=$(mktemp -d /tmp/flamegraph-XXXXXX)
ASPROF_PID=""

# Source environment for Pyroscope address
# shellcheck source=/dev/null
[ -f /etc/default/cassandra ] && source /etc/default/cassandra

# Source optional per-node profiler config (interval and extra args)
# shellcheck source=/dev/null
[ -f /etc/default/flamegraph-cassandra ] && source /etc/default/flamegraph-cassandra

PYROSCOPE_ADDR="${PYROSCOPE_SERVER_ADDRESS:-http://localhost:4040}"
INTERVAL="${FLAMEGRAPH_INTERVAL:-60}"

# Build extra args array; empty if FLAMEGRAPH_EXTRA_ARGS is unset or blank.
EXTRA_ARGS=()
if [ -n "${FLAMEGRAPH_EXTRA_ARGS:-}" ]; then
    # Word-split intentionally to expand space-separated options into array elements.
    # shellcheck disable=SC2206
    EXTRA_ARGS=($FLAMEGRAPH_EXTRA_ARGS)
fi

upload_file() {
    local f="$1"
    local until from
    # Use file mtime as the end of the profiling interval.
    until=$(stat -c %Y "$f")
    from=$((until - INTERVAL))
    curl -sf -X POST \
        "${PYROSCOPE_ADDR}/ingest?name=${APP_NAME}&spyName=asyncprofiler&format=collapsed&from=${from}&until=${until}" \
        -H "Content-Type: text/plain" \
        --data-binary @"$f" \
        || echo "Upload failed at $(date -Iseconds), continuing..."
    rm -f "$f"
    echo "Profile sent to Pyroscope ($(date -d @"${from}" -Iseconds) to $(date -d @"${until}" -Iseconds))"
}

cleanup() {
    echo "Stopping profiler..."
    if [ -n "$ASPROF_PID" ]; then
        kill "$ASPROF_PID" 2>/dev/null || true
        wait "$ASPROF_PID" 2>/dev/null || true
    fi
    # Upload any remaining completed files before exiting.
    for f in "${OUTDIR}"/profile-*.collapsed; do
        [ -f "$f" ] && upload_file "$f" || true
    done
    rm -rf "$OUTDIR"
}
trap cleanup EXIT

# Get the Cassandra PID
PID=$(cassandra-pid)

if [ -z "$PID" ] || [ "$PID" = "0" ]; then
    echo "Error: Could not determine Cassandra PID" >&2
    exit 1
fi

echo "Starting continuous profiling (interval: ${INTERVAL}s, PID: $PID, app: $APP_NAME)..."

# Start async-profiler with --loop for native continuous profiling.
# --loop <N>s: profile in a loop, writing one output file per interval, then reset.
# %t in the filename is replaced with a timestamp so each interval gets a unique file.
sudo "$ASPROF" --loop "${INTERVAL}s" -o collapsed \
    -f "${OUTDIR}/profile-%t.collapsed" \
    "${EXTRA_ARGS[@]}" "$PID" &
ASPROF_PID=$!

# Poll for completed profile files and upload them.
# Files are removed after upload so only unprocessed files remain at any time.
while kill -0 "$ASPROF_PID" 2>/dev/null; do
    for f in "${OUTDIR}"/profile-*.collapsed; do
        [ -f "$f" ] && upload_file "$f" || true
    done
    sleep 5
done

wait "$ASPROF_PID" 2>/dev/null || true
