[Unit]
Description=Flamegraph profiler for Cassandra (one-shot, sends to Pyroscope)
After=cassandra.service

[Service]
Type=oneshot
ExecStart=/usr/local/bin/flamegraph-to-pyroscope -d 30
EnvironmentFile=-/etc/default/cassandra
RemainAfterExit=no

# No [Install] section: this unit is triggered by the CLI (easy-db-lab cassandra profile),
# not enabled for automatic start via systemctl enable.
