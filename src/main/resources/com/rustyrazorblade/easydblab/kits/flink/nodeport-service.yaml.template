apiVersion: v1
kind: Service
metadata:
  name: flink-session-ui
  namespace: default
spec:
  type: NodePort
  # The operator labels the JobManager pod app=<FlinkDeployment name>, component=jobmanager.
  # The Flink REST API and Web UI are served by the JobManager on 8081.
  selector:
    app: flink-session
    component: jobmanager
  ports:
    - name: rest
      port: 8081
      targetPort: 8081
      nodePort: 30081
