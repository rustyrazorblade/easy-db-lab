      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sysbench_lat_p50_ms{kit=~\"$kit\"}",
          "legendFormat": "p50 {{kit}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sysbench_lat_p95_ms{kit=~\"$kit\"}",
          "legendFormat": "p95 {{kit}}",
          "refId": "B"
