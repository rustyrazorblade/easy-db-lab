  "refresh": "10s",
  "schemaVersion": 38,
  "tags": ["sysbench", "benchmark"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Datasource",
        "multi": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "regex": "VictoriaMetrics",
        "type": "datasource"
      },
      {
        "current": {},
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "definition": "label_values(sysbench_tps, kit)",
        "hide": 0,
        "includeAll": true,
        "label": "Kit",
        "multi": true,
        "name": "kit",
        "options": [],
        "query": {
          "query": "label_values(sysbench_tps, kit)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Sysbench Benchmark",
  "uid": "sysbench",
  "version": 1
