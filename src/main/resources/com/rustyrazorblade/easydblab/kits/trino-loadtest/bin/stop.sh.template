#!/usr/bin/env bash
set -euo pipefail

LABELS="easydblab.com/kit=${KIT_NAME},easydblab.com/role=trino-loadtest-run"

echo "Stopping trino-loadtest (deleting pod + ConfigMap by label selector: ${LABELS})..."
kubectl --kubeconfig="${KUBECONFIG}" delete pods -l "${LABELS}" --ignore-not-found
kubectl --kubeconfig="${KUBECONFIG}" delete configmaps -l "${LABELS}" --ignore-not-found

echo "trino-loadtest stopped. Read-only workload; no target-side data to clean up."
